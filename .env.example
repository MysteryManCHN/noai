# ============================================
# 飞书会议智能助手 - 环境变量配置示例
# ============================================
# 复制本文件为 .env 并填写实际值

# ============================================
# LLM 配置
# ============================================

# LLM 提供商 (openai / anthropic / deepseek)
LLM_PROVIDER=openai

# OpenAI API Key
OPENAI_API_KEY=sk-your-openai-api-key-here

# Anthropic API Key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# DeepSeek API Key
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# 使用的模型名称
LLM_MODEL=gpt-4o

# 生成温度 (0.0 - 1.0)
LLM_TEMPERATURE=0.3

# ============================================
# 运行时配置
# ============================================

# 轮询会议事件的间隔(秒)
POLL_INTERVAL=30

# 生成会议摘要的间隔(秒)
SUMMARY_INTERVAL=300

# 是否启用自动响应 (true / false)
AUTO_RESPONSE=true

# ============================================
# 飞书 CLI 配置
# ============================================

# lark-cli 可执行文件路径
LARK_CLI_PATH=/usr/local/bin/lark-cli

# ============================================
# 日志配置
# ============================================

# 日志级别 (DEBUG / INFO / WARNING / ERROR / CRITICAL)
LOG_LEVEL=INFO
